# Canonical production URL (set in Vercel → Project → Environment Variables)
NEXT_PUBLIC_SITE_URL=https://krisonsmarketing.com

# Web3Forms access key for the contact enquiry form.
# Get a free key at https://web3forms.com using krisonsmarketing@gmail.com —
# submissions will be delivered to that inbox. Without this key the form
# shows a fallback asking visitors to email directly.
NEXT_PUBLIC_WEB3FORMS_KEY=
